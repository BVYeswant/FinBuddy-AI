# ─────────────────────────────────────────────────────────────
#  FinBuddy AI — Environment Variables
# ─────────────────────────────────────────────────────────────

# ── LLM Providers (add at least ONE) ──────────────────────────
# FREE — Priority 1: OpenRouter (free models available)
# Sign up: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# FREE — Priority 2: Google Gemini
# Sign up: https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Priority 3: Grok (xAI)
GROK_API_KEY=your_grok_key_here
# PAID fallback — Priority 4: OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Finance Data APIs ──────────────────────────────────────────
# FREE tier: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# FREE tier (250 req/day): https://financialmodelingprep.com/
FMP_API_KEY=

# FREE tier: https://finnhub.io/
FINNHUB_API_KEY=

# FREE tier (1500 req/month): https://www.exchangerate-api.com/
EXCHANGERATE_API_KEY=

# ── Memory ─────────────────────────────────────────────────────
# Local Redis (or Redis Cloud free tier)
REDIS_URL=redis://localhost:6379

# Optional: Supabase
SUPABASE_URL=
SUPABASE_KEY=


# ── LangSmith Tracing (optional) ──────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=finbuddy-ai

# ── App ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
